function leet() {
    folder=`pbpaste | cut -d/ -f 5`
    mkdir $folder
    echo "# `pbpaste`" > $folder/__init__.py
    echo "# " >> $folder/__init__.py
    echo "from typing import Optional, List" >> $folder/__init__.py
    echo "from neetcode import null, true, false, will_fail" >> $folder/__init__.py
    echo "from neetcode import TreeNode, leets, leet_obj, parse_raw_examples" >> $folder/__init__.py

    echo "" >> $folder/__init__.py
    echo "" >> $folder/__init__.py
    echo "" >> $folder/__init__.py
    echo '        pass' >> $folder/__init__.py
    echo "" >> $folder/__init__.py
    echo 'if __name__ == "__main__":' >> $folder/__init__.py
    echo '    p = parse_raw_examples("""' >> $folder/__init__.py
    echo '' >> $folder/__init__.py
    echo '    """,' >> $folder/__init__.py
    echo '    map_input_func=None,' >> $folder/__init__.py
    echo '    map_input_keys=None,' >> $folder/__init__.py
    echo '    map_output_func=None,' >> $folder/__init__.py
    echo '    )' >> $folder/__init__.py
    echo '    expects = [' >> $folder/__init__.py
    echo '    (dict(),),' >> $folder/__init__.py
    echo ']' >> $folder/__init__.py
    echo '' >> $folder/__init__.py
    echo '    leets(Solution()., p.expects)' >> $folder/__init__.py
    echo "" >> $folder/__init__.py
    code --reuse-window $folder/__init__.py
}

# Open Pull Requests after creating new remote branches
# https://tighten.com/insights/open-github-pull-request-from-terminal/
function gpr() {
	github_url=$(git remote -v | awk '/fetch/{print $2}' | sed -Ee 's#(git@|git://)#https://#' -e 's@com:@com/@' -e 's%\.git$%%' | awk '/github/')
	branch_name=$(git symbolic-ref HEAD | cut -d"/" -f 3,4)
	pr_url=$github_url"/compare/main..."$branch_name
	open $pr_url
}

