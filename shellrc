function sunim {
    pushd `mktemp -d`
    yt-dlp --write-subs --sub-lang en --skip-download $1
    cat *.en.vtt | python -c """
import os
import sys


def clean_vtt(vtt_data: str):
    out_lines = []

    out_line = ''

    def append_out_line():
        nonlocal out_line, out_lines
        if out_line:
            out_lines.append(out_line.strip())
        if '.' in out_line or '?' in out_line:
            out_lines.append('\n')
        out_line = ''

    found_first = False
    for raw_line in vtt_data.split('\n'):
        if '-->' in raw_line:
            found_first = True

        if not found_first:
            continue

        if '-->' in raw_line:
            append_out_line()
            continue

        clean_line = raw_line.strip().replace('\n', ' ')

        out_line = f'{out_line} {clean_line}'

    append_out_line()
    return ' '.join(out_lines)


def clean_vtt_file(file_location: str):
    with open(file_location) as f:
        return clean_vtt(f.read())


if __name__ == '__main__':
    print(clean_vtt(sys.stdin.read()))
