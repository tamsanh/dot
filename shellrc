# Easy uuid creation
function uuid {
    python -c """
from uuid import uuid4
import sys
id = str(uuid4())
sys.stdout.write(id)
# sys.stderr.write(id)
"""
}

# Get the IP address of an aws instance by name
function awsip {
    instance_name=${1}
    aws ec2 describe-instances --filters "Name=tag:Name,Values=${instance_name}" | jq -r '.Reservations[0].Instances[0].PublicIpAddress'
}

