function hlog {
    git log --date-order --all --graph --format="%C(green)%h %Creset%C(yellow)%an%Creset %C(blue bold)%ar%Creset %C(red bold)%d%Creset %s" $@
}

alias hl="hlog"

function gi {
    # Generate git ignore files
    curl https://www.toptal.com/developers/gitignore/api/$1
}


# Open Pull Requests after creating new remote branches
function gpr() {
    # Ex. https://github.com/ORG/REPO/pull/new/BRANCH
    set -x
    branch=`git branch --show-current`
    origin=`cat .git/config | fgrep -A 2 "\"origin\"" | fgrep url | cut -d':' -f 2`
    org=`echo $origin | cut -d '/' -f 1`
    repo=`echo ${origin%%.*} | cut -d '/' -f 2`
    open "https://github.com/${org}/${repo}/pull/new/${branch}"
}

# LESS with color
alias lc="less -R"

# Easy uuid creation
function uuid {
    python -c """
from uuid import uuid4
import sys
id = str(uuid4())
sys.stdout.write(id)
# sys.stderr.write(id)
"""
}

# Get the IP address of an aws instance by name
function awsip {
    instance_name=${1}
    aws ec2 describe-instances --filters "Name=tag:Name,Values=${instance_name}" | jq -r '.Reservations[0].Instances[0].PublicIpAddress'
}

