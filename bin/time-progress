#!/usr/bin/env bash
# time-progress — current hour progress as a vertical bar

_get_height() {
  local lines
  lines=$(stty size </dev/tty 2>/dev/null | cut -d' ' -f1)
  [[ -z "$lines" || "$lines" -le 0 ]] && lines=$(tput lines 2>/dev/null || echo 40)
  printf '%s' "$lines"
}

_dir_color() {
  printf '%s' "${PWD##*/}" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}'
}

_bar_color() {
  printf 'TIME_%s' "${PWD##*/}" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}'
}

tput civis 2>/dev/null

prev_snapshot=""
window_resized=0
trap 'window_resized=1' SIGWINCH
trap 'tput cnorm 2>/dev/null; exit' INT TERM

_redraw() {
  local height
  height=$(_get_height)

  local minute second
  minute=$(date +%M)
  second=$(date +%S)

  local elapsed_secs=$(( 10#$minute * 60 + 10#$second ))
  local usage_pct=$(( elapsed_secs * 100 / 3600 ))
  local time_str
  time_str=$(date +%H:%M:%S)
  local remaining=$(( 59 - 10#$minute ))m

  local snapshot="${elapsed_secs}:${height}"
  if [[ "$snapshot" == "$prev_snapshot" && "$window_resized" -eq 0 ]]; then
    return
  fi
  prev_snapshot="$snapshot"
  window_resized=0

  local dir="${PWD##*/}"
  dir="${dir:0:8}"
  local lpad=$(( (8 - ${#dir}) / 2 ))
  local dir_color bar_color
  dir_color=$(_dir_color)
  bar_color=$(_bar_color)

  # Fixed lines: title(1) + div + time + remaining = 4
  local bar_height=$(( height - 4 ))
  [[ $bar_height -lt 1 ]] && bar_height=1

  local filled=$(( bar_height * usage_pct / 95 ))
  [[ $filled -lt 1 ]] && filled=1
  [[ $filled -gt $bar_height ]] && filled=$bar_height

  # Filled region grows from center outward
  local fill_start=$(( bar_height / 2 - filled / 2 ))
  local fill_end=$(( fill_start + filled ))

  clear
  printf "\033[1;48;5;%sm%*s%s%*s\033[0m\n" "$dir_color" "$lpad" '' "$dir" "$(( 8 - ${#dir} - lpad ))" ''

  local i
  for (( i = 0; i < bar_height; i++ )); do
    if (( i >= fill_start && i < fill_end )); then
      printf "\033[38;5;%sm%s\033[0m\n" "$bar_color" "████████"
    else
      echo ""
    fi
  done

  printf "\033[1;38;5;240m%s\033[0m\n" "────────"
  printf "\033[38;5;%sm%s\033[0m\n" "$bar_color" "${time_str:0:8}"
  printf "\033[38;5;%sm%s\033[0m" "$dir_color" "${remaining:0:8}"
}

_redraw

while true; do
  sleep 1
  _redraw
done
