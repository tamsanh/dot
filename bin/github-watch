#!/usr/bin/env bash
# github-watch — display GitHub PR check statuses
# Git operations run locally; GitHub API data read from github-watch-fetcher.
# Usage: github-watch [interval-seconds]  (default: 10)

interval="${1:-10}"
data_dir="$HOME/.stats/github-watch-$(printf '%s' "$PWD" | cksum | awk '{print $1}')"

in_tmux=0
[[ -n "$TMUX" ]] && in_tmux=1

tput civis 2>/dev/null  # hide cursor

git_limit=5
action_limit=5
entries=()
gh_lines=""
gh_rate_remaining=""
gh_rate_reset=""

_recalc_limits() {
  local lines
  lines=$(stty size </dev/tty 2>/dev/null | cut -d' ' -f1)
  [[ -z "$lines" || "$lines" -le 0 ]] && lines=$(tput lines 2>/dev/null || echo 40)
  # Fixed lines: title(1) + div(1) + bottom_div(1) + rate(1) + reset(1) = 5; tmux=4
  local fixed=$(( in_tmux ? 4 : 5 ))
  local remaining=$(( lines - fixed - git_limit ))
  # actions are 3 lines each (ref + name + blank)
  action_limit=$(( remaining / 3 ))
  [[ $action_limit -lt 1 ]] && action_limit=1
}

_sha_color() {
  printf '%s' "$1" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}'
}

_load_entries() {
  entries=()
  while IFS=$'\x1f' read -r sha parents time subject && [[ ${#entries[@]} -lt $git_limit ]]; do
    local ticket
    ticket=$(printf '%s' "$subject" | grep -ioE '[A-Z]{2,10}-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]')
    local num_parents
    num_parents=$(echo "$parents" | wc -w)
    [[ $num_parents -lt 2 && -z "$ticket" ]] && continue
    local short="${sha:0:7}"
    local color
    color=$(_sha_color "$short")
    entries+=("${time}|${ticket:-$short}|${color}")
  done < <(git log main --first-parent --format="%H%x1f%P%x1f%cd%x1f%s" --date=format:"%H:%M:%S" 2>/dev/null)

  if [[ ${#entries[@]} -eq 0 ]]; then
    while IFS=$'\x1f' read -r sha time && [[ ${#entries[@]} -lt $git_limit ]]; do
      local short="${sha:0:7}"
      local color
      color=$(_sha_color "$short")
      entries+=("${time}|${short}|${color}")
    done < <(git log main --first-parent --format="%H%x1f%cd" --date=format:"%H:%M:%S" 2>/dev/null)
  fi
}

_format_rate_reset() {
  local epoch="$1"
  [[ ! "$epoch" =~ ^[0-9]+$ ]] && return
  local secs=$(( epoch - $(date +%s) ))
  (( secs <= 0 )) && return
  if   (( secs >= 3600 )); then printf '%dh%dm' $(( secs / 3600 )) $(( (secs % 3600) / 60 ))
  elif (( secs >= 60   )); then printf '%dm%ds' $(( secs / 60 )) $(( secs % 60 ))
  else                          printf '%ds' "$secs"
  fi
}

_load_gh_data() {
  [[ -f "$data_dir/rate"       ]] && gh_rate_remaining=$(< "$data_dir/rate")
  [[ -f "$data_dir/rate_reset" ]] && gh_rate_reset=$(< "$data_dir/rate_reset")
  [[ -f "$data_dir/gh_lines"   ]] && gh_lines=$(< "$data_dir/gh_lines")
}

_draw_actions() {
  [[ -z "$gh_lines" || $action_limit -le 0 ]] && return
  local i=0
  while IFS=$'\t' read -r status conclusion title branch headsha wfname rawname && [[ $i -lt $action_limit ]]; do
    [[ "$conclusion" == "cancelled" || "$conclusion" == "skipped" ]] && continue
    (( i++ ))
    local color
    case "$status" in
    in_progress)    color=214 ;;
    queued|waiting) color=172 ;;
    completed)
      case "$conclusion" in
      success) color=82  ;;
      failure) color=196 ;;
      *)       color=244 ;;
      esac ;;
    *) color=244 ;;
    esac
    local ticket
    ticket=$(printf '%s' "$branch $title" | grep -ioE '[A-Z]{2,10}-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]')
    local ref="${ticket:-${headsha:0:7}}"
    local display_name="${rawname:-$wfname}"
    [[ -z "$display_name" && -n "$title" ]] && display_name="${title%% *}"
    printf "\033[1;38;5;%sm%s\033[0m\n" "$color" "${ref:0:8}"
    printf "\033[38;5;%sm%s\033[0m\n"   "$color" "${display_name:0:8}"
    echo ""
  done <<< "$gh_lines"
}

prev_snapshot=""
window_resized=0
trap 'window_resized=1' SIGWINCH
trap 'tput cnorm 2>/dev/null; exit' INT TERM

_redraw() {
  local height
  height=$(stty size </dev/tty 2>/dev/null | cut -d' ' -f1)
  [[ -z "$height" || "$height" -le 0 ]] && height=$(tput lines 2>/dev/null || echo 40)

  local current_snapshot="${entries[*]}${gh_lines}${gh_rate_remaining}${gh_rate_reset}"
  if [[ "$current_snapshot" == "$prev_snapshot" && $window_resized -eq 0 ]]; then
    return
  fi
  prev_snapshot="$current_snapshot"
  window_resized=0

  local dir="${PWD##*/}"
  dir="${dir:0:8}"
  local lpad=$(( (8 - ${#dir}) / 2 ))
  local dir_color
  dir_color=$(printf '%s' "$dir" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}')

  clear
  if [[ $in_tmux -eq 0 ]]; then
    printf "\033[1;48;5;%sm%*s%s%*s\033[0m\n" "$dir_color" "$lpad" '' "$dir" "$(( 8 - ${#dir} - lpad ))" ''
  fi

  for entry in "${entries[@]}"; do
    local rest="${entry#*|}"
    local label="${rest%|*}"
    local c="${rest##*|}"
    printf "\033[1;38;5;%sm%s\033[0m\n" "$c" "$label"
  done

  printf "\033[1;38;5;240m%s\033[0m\n" "────────"
  _draw_actions
  printf "\033[1;38;5;240m%s\033[0m\n" "────────"
  local rate_val="${gh_rate_remaining:-????}"
  local rate_color=82
  [[ "$rate_val" =~ ^[0-9]+$ && "$rate_val" -lt 500  ]] && rate_color=196
  [[ "$rate_val" =~ ^[0-9]+$ && "$rate_val" -ge 500 && "$rate_val" -lt 1500 ]] && rate_color=214
  printf "\033[38;5;%sm%.8s\033[0m\n" "$rate_color" "$rate_val"
  printf "\033[38;5;240m%.8s\033[0m\n" "$(_format_rate_reset "$gh_rate_reset")"
  # Park cursor at last row without a newline so the terminal doesn't scroll
  printf "\033[%d;1H" "$height"
}

_recalc_limits
git pull origin main &>/dev/null
_load_entries
_load_gh_data
_redraw

while true; do
  sleep "$interval"
  _recalc_limits
  git pull origin main &>/dev/null
  _load_entries
  _load_gh_data
  _redraw
done
