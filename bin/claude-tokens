#!/usr/bin/env bash
# claude-tokens — Claude Code 5-hour block usage as a vertical bar
# Reads from claude-tokens-fetcher; start that first (or via watch-pane).
# Usage: claude-tokens

data_file="$HOME/.stats/claude-tokens"

_get_height() {
  local lines
  lines=$(stty size </dev/tty 2>/dev/null | cut -d' ' -f1)
  [[ -z "$lines" || "$lines" -le 0 ]] && lines=$(tput lines 2>/dev/null || echo 40)
  printf '%s' "$lines"
}

_dir_color() {
  printf '%s' "${PWD##*/}" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}'
}

_bar_color() {
  printf 'BAR_%s' "${PWD##*/}" | cksum | awk '{split("196 202 208 214 220 226 190 154 118 82 46 86 51 87 123 159 33 57 93 129 165 201 207 171",c); print c[($1%24)+1]}'
}

usage_pct=0
reset_epoch=0
start_epoch=0
cost_str='$---'

_load_data() {
  [[ ! -f "$data_file" ]] && return
  local content
  content=$(< "$data_file")
  [[ -z "$content" ]] && return
  usage_pct=$(sed -n '1p' <<< "$content")
  cost_str=$(sed -n '2p'  <<< "$content")
  local epoch
  epoch=$(sed -n '3p' <<< "$content")
  [[ "$epoch" =~ ^[0-9]+$ ]] && reset_epoch="$epoch"
  local sepoch
  sepoch=$(sed -n '4p' <<< "$content")
  [[ "$sepoch" =~ ^[0-9]+$ ]] && start_epoch="$sepoch"
}

_format_reset() {
  local secs=$(( reset_epoch - $(date +%s) ))
  if [[ $secs -le 0 ]]; then
    printf '%s' '----'
    return
  fi
  if [[ $secs -ge 3600 ]]; then
    printf '%dh%dm' $(( secs / 3600 )) $(( (secs % 3600) / 60 ))
  elif [[ $secs -ge 60 ]]; then
    printf '%dm%ds' $(( secs / 60 )) $(( secs % 60 ))
  else
    printf '%ds' "$secs"
  fi
}

_format_elapsed() {
  [[ $start_epoch -eq 0 ]] && printf '%s' '--:--' && return
  local secs=$(( $(date +%s) - start_epoch ))
  [[ $secs -lt 0 ]] && secs=0
  printf '%02d:%02d' $(( secs / 3600 )) $(( (secs % 3600) / 60 ))
}

tput civis 2>/dev/null  # hide cursor

prev_snapshot=""
window_resized=0
trap 'window_resized=1' SIGWINCH
trap 'tput cnorm 2>/dev/null; exit' INT TERM

_redraw() {
  local height
  height=$(_get_height)

  local reset_str elapsed_str
  reset_str=$(_format_reset)
  elapsed_str=$(_format_elapsed)

  # Include reset_str/elapsed_str so the countdown triggers a redraw each second
  local snapshot="${usage_pct}:${cost_str}:${reset_str}:${elapsed_str}:${height}"
  if [[ "$snapshot" == "$prev_snapshot" && "$window_resized" -eq 0 ]]; then
    return
  fi
  prev_snapshot="$snapshot"
  window_resized=0

  local dir="${PWD##*/}"
  dir="${dir:0:8}"
  local lpad=$(( (8 - ${#dir}) / 2 ))
  local dir_color bar_color
  dir_color=$(_dir_color)
  bar_color=$(_bar_color)

  # Fixed lines: title (1) + bottom-div + elapsed + reset-time + dollar-value = 5
  local bar_height=$(( height - 5 ))
  [[ $bar_height -lt 1 ]] && bar_height=1

  local filled=$(( bar_height * usage_pct / 95 ))
  [[ $filled -lt 1 ]] && filled=1
  [[ $filled -gt $bar_height ]] && filled=$bar_height

  # Filled region grows from center outward
  local fill_start=$(( bar_height / 2 - filled / 2 ))
  local fill_end=$(( fill_start + filled ))

  clear
  printf "\033[1;48;5;%sm%*s%s%*s\033[0m\n" "$dir_color" "$lpad" '' "$dir" "$(( 8 - ${#dir} - lpad ))" ''

  local i
  for (( i = 0; i < bar_height; i++ )); do
    if (( i >= fill_start && i < fill_end )); then
      printf "\033[38;5;%sm%s\033[0m\n" "$bar_color" "████████"
    else
      echo ""
    fi
  done

  printf "\033[1;38;5;240m%s\033[0m\n" "────────"
  printf "\033[38;5;%sm%s\033[0m\n" "$bar_color" "${elapsed_str:0:8}"
  printf "\033[38;5;%sm%s\033[0m\n" "$dir_color" "${reset_str:0:8}"
  printf "\033[38;5;%sm%s\033[0m" "$dir_color" "${cost_str:0:8}"
}

_load_data
_redraw

while true; do
  sleep 1
  _load_data
  _redraw
done
