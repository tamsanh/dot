#!/usr/bin/env bash
# git-pull-watch — Periodically pull origin main, report only when HEAD changes
# Usage: git-pull-watch [count] [interval-in-seconds]  (defaults: 10 commits, 10s)

count="${1:-25}"
interval="${2:-10}"

# Derive a dark background color from the directory name and restore on exit
_dir_bg_hex() {
  local checksum
  checksum=$(printf '%s' "${PWD##*/}" | cksum | awk '{print $1}')
  python3 -c "
import colorsys
h = $checksum % 360
r, g, b = colorsys.hls_to_rgb(h / 360, 0.12, 0.25)
print(f'{int(r*255):02x}{int(g*255):02x}{int(b*255):02x}')
"
}

## Uncomment to change the background color
# printf "\033]11;#2e2e4e\007"
# trap 'printf "\033]111;\007"' EXIT

_sha_color() {
  printf '%s' "$1" | cksum | awk '{print ($1 % 200) + 50}'
}

_load_entries() {
  entries=()
  while IFS=' ' read -r sha time; do
    local short="${sha:0:7}"
    local color
    color=$(_sha_color "$short")
    entries+=("${time}|${short}|${color}")
  done < <(git log main -"$count" --format="%H %cd" --date=format:"%H:%M:%S" 2>/dev/null)
}

_redraw() {
  local dir="${PWD##*/}"
  dir="${dir:0:8}"
  local dir_color
  dir_color=$(printf '%s' "$dir" | cksum | awk '{print ($1 % 200) + 50}')
  clear
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "|======>"
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "$dir"
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "|======>"
  echo ""
  echo ""
  for entry in "${entries[@]}"; do
    local time="${entry%%|*}"
    local rest="${entry#*|}"
    local sha="${rest%|*}"
    local c="${rest##*|}"
    echo "$time"
    printf "\033[1;38;5;%sm%s\033[0m\n" "$c" "$sha"
    echo ""
  done
}

_load_entries
last_sha=$(git rev-parse origin/main 2>/dev/null)
_redraw

while true; do
  git pull origin main &>/dev/null
  _load_entries
  current_sha=$(git rev-parse origin/main 2>/dev/null)
  if [[ "$current_sha" != "$last_sha" ]]; then
    last_sha="$current_sha"
  fi
  _redraw
  sleep "$interval"
done
