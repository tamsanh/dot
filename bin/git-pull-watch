#!/usr/bin/env bash
# git-pull-watch — Periodically pull origin main, report only when HEAD changes
# Usage: git-pull-watch [count] [interval-in-seconds]  (defaults: 10 commits, 10s)

count="${1:-25}"
interval="${2:-10}"

# Even split: actions get the odd slot when count is odd
git_limit=$(( count / 2 ))
action_limit=$(( count - count / 2 ))

# Derive a dark background color from the directory name and restore on exit
_dir_bg_hex() {
  local checksum
  checksum=$(printf '%s' "${PWD##*/}" | cksum | awk '{print $1}')
  python3 -c "
import colorsys
h = $checksum % 360
r, g, b = colorsys.hls_to_rgb(h / 360, 0.12, 0.25)
print(f'{int(r*255):02x}{int(g*255):02x}{int(b*255):02x}')
"
}

## Uncomment to change the background color
# printf "\033]11;#2e2e4e\007"
# trap 'printf "\033]111;\007"' EXIT

_sha_color() {
  printf '%s' "$1" | cksum | awk '{print ($1 % 200) + 50}'
}

_load_entries() {
  entries=()
  # Use $'\x1f' (unit separator) so spaces in subjects don't break field parsing.
  # %P gives space-separated parent SHAs; word count >= 2 means merge commit.
  # Scan without a hard limit so filtering doesn't starve the entry count.
  while IFS=$'\x1f' read -r sha parents time subject && [[ ${#entries[@]} -lt $git_limit ]]; do
    local ticket
    ticket=$(printf '%s' "$subject" | grep -ioE '[A-Z]{2,10}-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]')
    local num_parents
    num_parents=$(echo "$parents" | wc -w)
    # Skip non-merge commits that have no ticket number
    [[ $num_parents -lt 2 && -z "$ticket" ]] && continue
    local short="${sha:0:7}"
    local color
    color=$(_sha_color "$short")
    local display="${ticket:-$short}"
    entries+=("${time}|${display}|${color}")
  done < <(git log main --first-parent --format="%H%x1f%P%x1f%cd%x1f%s" --date=format:"%H:%M:%S" 2>/dev/null)

  # Fallback: if nothing matched, show raw commits
  if [[ ${#entries[@]} -eq 0 ]]; then
    while IFS=$'\x1f' read -r sha time && [[ ${#entries[@]} -lt $git_limit ]]; do
      local short="${sha:0:7}"
      local color
      color=$(_sha_color "$short")
      entries+=("${time}|${short}|${color}")
    done < <(git log main --first-parent --format="%H%x1f%cd" --date=format:"%H:%M:%S" 2>/dev/null)
  fi
}

gh_lines=""

_load_actions() {
  gh_lines=$(gh run list --limit 50 \
    --json status,conclusion,displayTitle,headBranch,headSha,name \
    --jq '.[] | [.status, (.conclusion // ""), .displayTitle, .headBranch, .headSha, .name] | @tsv' 2>/dev/null)
}

_draw_actions() {
  [[ -z "$gh_lines" || $action_limit -le 0 ]] && return
  local i=0
  while IFS=$'\t' read -r status conclusion title branch headsha name && [[ $i -lt $action_limit ]]; do
    (( i++ ))
    local color icon
    case "$status" in
      in_progress)    color=214; icon="●" ;;
      queued|waiting) color=172; icon="○" ;;
      completed)
        case "$conclusion" in
          success)   color=82;  icon="✓" ;;
          failure)   color=196; icon="✗" ;;
          cancelled) color=244; icon="⊘" ;;
          *)         color=244; icon="?" ;;
        esac
        ;;
      *) color=244; icon="?" ;;
    esac
    # Prefer version tag, then ticket, then short commit SHA
    local combined="$branch $title"
    local version ticket
    version=$(printf '%s' "$combined" | grep -ioE 'v[0-9]+\.[0-9]+(\.[0-9]+)*' | head -1)
    ticket=$(printf '%s' "$combined"  | grep -ioE '[A-Z]{2,10}-[0-9]+' | head -1 | tr '[:lower:]' '[:upper:]')
    local ref="${version:-${ticket:-${headsha:0:7}}}"

    ## Uncomment to return icon, but removed because it's too crowded
    # printf "\033[1;38;5;%sm%s%s\033[0m\n" "$color" "$icon" "${ref:0:7}"

    printf "\033[1;38;5;%sm%s%s\033[0m\n" "$color" "${ref:0:7}"
    printf "\033[38;5;%sm%s\033[0m\n"     "$color" "${name:0:8}"
    echo ""
  done <<< "$gh_lines"
}

_redraw() {
  local dir="${PWD##*/}"
  dir="${dir:0:8}"
  local dir_color
  dir_color=$(printf '%s' "$dir" | cksum | awk '{print ($1 % 200) + 50}')
  clear
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "|======>"
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "$dir"
  printf "\033[1;38;5;%sm%s\033[0m\n" "$dir_color" "|======>"
  echo ""
  echo ""
  for entry in "${entries[@]}"; do
    local time="${entry%%|*}"
    local rest="${entry#*|}"
    local sha="${rest%|*}"
    local c="${rest##*|}"
    echo "$time"
    printf "\033[1;38;5;%sm%s\033[0m\n" "$c" "$sha"
    echo ""
  done
  echo ""
  _draw_actions
}

_load_entries
_load_actions
last_sha=$(git rev-parse origin/main 2>/dev/null)
_redraw

while true; do
  git pull origin main &>/dev/null
  _load_entries
  _load_actions
  current_sha=$(git rev-parse origin/main 2>/dev/null)
  if [[ "$current_sha" != "$last_sha" ]]; then
    last_sha="$current_sha"
  fi
  _redraw
  sleep "$interval"
done
