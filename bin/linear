#!/usr/bin/env bash
# linear — Thin wrapper around the Linear GraphQL API
# Usage:
#   linear get <TEAM-123 | https://linear.app/...>
#   Outputs JSON: { identifier, title, description, branchName, url }
#
# Requires: LINEAR_API_KEY env var

set -euo pipefail

API="https://api.linear.app/graphql"

if [[ -z "${LINEAR_API_KEY:-}" ]]; then
  echo "error: LINEAR_API_KEY is not set" >&2
  exit 1
fi

_graphql() {
  curl -s \
    -H "Authorization: ${LINEAR_API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$1" \
    "$API"
}

_extract_id() {
  local input="$1"
  # Match identifiers like ENG-123, TEAM-42, ABC-9999 (from URL or bare)
  if [[ "$input" =~ ([A-Za-z][A-Za-z0-9]+-[0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}" | tr '[:lower:]' '[:upper:]'
  else
    echo "error: cannot find a Linear identifier in: $input" >&2
    exit 1
  fi
}

cmd_get() {
  [[ $# -lt 1 ]] && { echo "Usage: linear get <TICKET-ID | URL>" >&2; exit 1; }

  local id
  id=$(_extract_id "$1")

  local payload
  payload=$(printf '{"query":"query($id:String!){issue(id:$id){identifier title description branchName url labels{nodes{name}} state{id name type} team{id}}}","variables":{"id":"%s"}}' "$id")

  local resp
  resp=$(_graphql "$payload")

  if echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); sys.exit(0 if 'errors' not in d else 1)" 2>/dev/null; then
    echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(json.dumps(d['data']['issue']))"
  else
    echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('errors',[{}])[0].get('message','unknown error'))" >&2
    exit 1
  fi
}

cmd_start() {
  [[ $# -lt 1 ]] && { echo "Usage: linear start <TICKET-ID | URL>" >&2; exit 1; }

  local id
  id=$(_extract_id "$1")

  # Fetch the team's workflow states
  local states_payload
  states_payload=$(printf '{"query":"query($id:String!){issue(id:$id){team{states{nodes{id name type}}}}}","variables":{"id":"%s"}}' "$id")
  local states_resp
  states_resp=$(_graphql "$states_payload")

  # Pick the best "started" state — prefer names suggesting active work
  local state_id
  state_id=$(echo "$states_resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
nodes = d['data']['issue']['team']['states']['nodes']
started = [s for s in nodes if s['type'] == 'started']
if not started:
    print('error: no started state found for this team', file=sys.stderr)
    sys.exit(1)
# Prefer states whose name implies active work over hold/blocked/review states
deprioritize = ('block', 'wait', 'hold', 'review', 'merge', 'paused')
preferred = [s for s in started if not any(w in s['name'].lower() for w in deprioritize)]
print((preferred or started)[0]['id'])
") || exit 1

  # Apply the state
  local update_payload
  update_payload=$(printf '{"query":"mutation($id:String!,$s:String!){issueUpdate(id:$id,input:{stateId:$s}){success}}","variables":{"id":"%s","s":"%s"}}' "$id" "$state_id")
  local update_resp
  update_resp=$(_graphql "$update_payload")

  echo "$update_resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
if d.get('data', {}).get('issueUpdate', {}).get('success'):
    print('marked as in-progress')
else:
    print('error: failed to update state', file=sys.stderr)
    sys.exit(1)
" || exit 1
}

cmd_create() {
  local title="" description="" label="" priority="medium" project="Northslope CLI"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -t|--title)       title="$2";       shift 2 ;;
      -d|--description) description="$2"; shift 2 ;;
      -l|--label)       label="$2";       shift 2 ;;
      -p|--priority)    priority="$2";    shift 2 ;;
      --project)        project="$2";     shift 2 ;;
      *) echo "Unknown option: $1" >&2; return 1 ;;
    esac
  done

  [[ -z "$title" ]] && {
    echo "Usage: linear create -t TITLE [-d DESC] [-l LABEL] [-p PRIORITY] [--project PROJECT]" >&2
    return 1
  }

  local priority_int
  case "$priority" in
    urgent) priority_int=1 ;;
    high)   priority_int=2 ;;
    medium) priority_int=3 ;;
    low)    priority_int=4 ;;
    none)   priority_int=0 ;;
    *) echo "Invalid priority '$priority'. Use: urgent|high|medium|low|none" >&2; return 1 ;;
  esac

  # Resolve project → team
  local projects_resp
  projects_resp=$(_graphql '{"query":"{ projects { nodes { id name teams { nodes { id } } } } }"}')

  local team_id project_id
  team_id=$(echo "$projects_resp" | python3 -c "
import sys, json, os
d = json.load(sys.stdin)
for p in d['data']['projects']['nodes']:
    if p['name'] == os.environ['LIN_PROJECT']:
        nodes = p['teams']['nodes']
        if nodes: print(nodes[0]['id'])
        break
" LIN_PROJECT="$project")

  project_id=$(echo "$projects_resp" | python3 -c "
import sys, json, os
d = json.load(sys.stdin)
for p in d['data']['projects']['nodes']:
    if p['name'] == os.environ['LIN_PROJECT']:
        print(p['id']); break
" LIN_PROJECT="$project")

  [[ -z "$team_id" ]] && { echo "error: project '$project' not found or has no team" >&2; return 1; }

  # Resolve label
  local label_id=""
  if [[ -n "$label" ]]; then
    local labels_resp
    labels_resp=$(_graphql '{"query":"{ issueLabels { nodes { id name } } }"}')
    label_id=$(echo "$labels_resp" | python3 -c "
import sys, json, os
d = json.load(sys.stdin)
name = os.environ['LIN_LABEL'].lower()
for l in d['data']['issueLabels']['nodes']:
    if l['name'].lower() == name:
        print(l['id']); break
" LIN_LABEL="$label")
    [[ -z "$label_id" ]] && echo "warning: label '$label' not found, creating without label" >&2
  fi

  # Build mutation payload safely via Python
  local payload
  payload=$(python3 -c "
import json, os
inp = {
    'title':     os.environ['LIN_TITLE'],
    'teamId':    os.environ['LIN_TEAM'],
    'priority':  int(os.environ['LIN_PRIORITY']),
}
if os.environ.get('LIN_DESC'):    inp['description'] = os.environ['LIN_DESC']
if os.environ.get('LIN_PROJECT'): inp['projectId']   = os.environ['LIN_PROJECT']
if os.environ.get('LIN_LABEL'):   inp['labelIds']     = [os.environ['LIN_LABEL']]
print(json.dumps({
    'query': 'mutation Create(\$i: IssueCreateInput!) { issueCreate(input: \$i) { success issue { identifier title url } } }',
    'variables': {'i': inp}
}))
" \
    LIN_TITLE="$title" \
    LIN_TEAM="$team_id" \
    LIN_PRIORITY="$priority_int" \
    LIN_DESC="$description" \
    LIN_PROJECT="$project_id" \
    LIN_LABEL="$label_id")

  local resp
  resp=$(_graphql "$payload")

  echo "$resp" | python3 -c "
import sys, json
d = json.load(sys.stdin)
issue = d.get('data', {}).get('issueCreate', {})
if issue.get('success'):
    i = issue['issue']
    print(f\"{i['identifier']}: {i['title']}\")
    print(f\"  {i['url']}\")
else:
    errs = d.get('errors') or [{}]
    print('error:', errs[0].get('message', json.dumps(d)), file=sys.stderr)
    sys.exit(1)
" || return 1
}

case "${1:-}" in
  get)    shift; cmd_get    "$@" ;;
  start)  shift; cmd_start  "$@" ;;
  create) shift; cmd_create "$@" ;;
  *)
    echo "Usage: linear get    <TICKET-ID | URL>" >&2
    echo "       linear start  <TICKET-ID | URL>" >&2
    echo "       linear create -t TITLE [-d DESC] [-l LABEL] [-p PRIORITY] [--project PROJECT]" >&2
    exit 1
    ;;
esac
